WINDOWS:
  ZHIPU:
    API_KEY: "<your-zhipu-api-key>"
    MODEL_NAME: "glm-4-flash-250414"
    TEMPERATURE: 0.7
    MAX_TOKENS: 4096

  APP:
    DEBUG: true
    LOG_LEVEL: "INFO"

  JWT:
    SECRET_KEY: "<your-jwt-secret-key>"
    ALGORITHM: "HS256"
    ACCESS_TOKEN_EXPIRE_HOURS: 24

  MYSQL:
    HOST: "localhost"
    PORT: 3306
    USER: "root"
    PASSWORD: "root"
    DB: "resume_db"

  CHROMA:
    PERSIST_DIR: "chroma_db"
    COLLECTION_RESUME: "resume_collection"
    COLLECTION_JOB: "job_collection"

  RAG:
    CHUNK_SIZE: 500
    CHUNK_OVERLAP: 50
    TOP_K: 3

  VECTOR_STORE:
    ENABLED: true
    MAX_RETRIES: 2
    RETRY_DELAY: 1.0
    REQUEST_DELAY: 1.0

