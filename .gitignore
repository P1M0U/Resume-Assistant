# ===================================================================
# 项目根目录.gitignore文件
# 合并了前后端的忽略规则
# ===================================================================

# -----------------------------
# 通用忽略规则
# -----------------------------
# 操作系统文件
.DS_Store
Thumbs.db

# 编辑器目录和文件
**/.vscode/
.trae/**
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 日志文件
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------
# 前端Vue项目忽略规则
# -----------------------------
# 依赖目录
node_modules

# 构建输出
dist
dist-ssr

# 测试覆盖率
coverage

# Cypress测试文件
/cypress/videos/
/cypress/screenshots/

# 本地配置文件
*.local

# TypeScript构建信息
!*.tsbuildinfo

# -----------------------------
# 后端Python项目忽略规则
# -----------------------------
# Python缓存目录
__pycache__/
**/__pycache__/

# Alembic迁移文件
Backend/app/alembic/versions/*

# Python字节码文件
*.pyc
*.pyo
*.pyd

# 忽略__init__.py文件（如果需要）
__init__.py
**/__init__.py

# -----------------------------
# 其他忽略规则
# -----------------------------
# 环境配置文件
.env
.env.local
.env.*.local

# Docker相关
.dockerignore

# 临时文件
*.tmp
*.temp
.cache